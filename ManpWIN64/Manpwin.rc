MANPWIN MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "O&pen PNG Image File..\tG",   IDM_OPEN_PNG
        MENUITEM "&Open Parameter File...\tO",  IDM_OPEN_PAR
        MENUITEM "Open An&im Script File...\tI", IDM_OPEN_SCI
        MENUITEM "Open animation frame PNG list (*.lst)\t<Shft>L", IDM_OPEN_LST
        MENUITEM "Open Kalles Fraktaler File\tK", IDM_OPEN_KALLES
        MENUITEM "&Save Parameters\tS",         IDM_SAVEPAR
        MENUITEM "Save Im&age...\tA",           IDM_SAVEIMAGE
        MENUITEM "Save Both Parameters and Image\t<Ctrl><Shft>S", IDM_SAVE_PAR_AND_IMAGE
        MENUITEM "Save Kalles Fraktaler File\t<Ctrl>K", IDM_SAVE_KALLES
        MENUITEM SEPARATOR
        MENUITEM "E&xit\tESC or Enter",         IDM_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "Copy to ClipBoard\tCtrl+C",   IDM_COPY
        MENUITEM "Undo\tCtrl+Z",                IDM_UNDO
        MENUITEM "Redo\tCtrl+Y",                IDM_REDO
    END
    POPUP "F&ractals"
    BEGIN
        MENUITEM "&Fractal Type\tT",            IDC_FRACTYPE
        MENUITEM "&Update Current Fractal Information\tCtrl+T", IDM_UPDATE_FRACTAL
        MENUITEM "F&ractal Options\tX",         IDM_FRACOPTIONS
        MENUITEM "3D Parameters\tD",            IDM_3DPARAM
        MENUITEM "Toggle Perturbation\tW",      IDM_TOGGLEPERT
        MENUITEM "&Display Fractal Status Information\tTab", IDM_FRACTLOC
        MENUITEM "&Enter Fractal Co-ordinates\tCtrl+F", IDM_FRACTALCOORDS
        MENUITEM "&Tierazon Filter FD-Options\tF", IDM_FDOPTIONS
    END
    POPUP "Setup"
    BEGIN
        MENUITEM "&3D Plot\t3",                 IDM_3D
        MENUITEM "&Julia Fractal\tSpace",       IDM_JULIA
        MENUITEM "Real Time Julia\tCtrl+Space", IDM_REALTIMEJULIA
        MENUITEM "Set Real Time Julia Set Thumbnail Size\tShift+Space", IDM_SET_JULIA_SIZE
        MENUITEM "&Random Dot Stereogram\tR",   IDM_RDS
        MENUITEM "Toggle Random Dot Stereogram Guide Spots\tShift+R", IDM_RDS_SPOTS
        MENUITEM "&Stereo Pairs\tZ",            IDM_STEREO
        MENUITEM "&Add Images\tY",              IDC_ADDSPIRAL
        MENUITEM "Zoom Along Edge\tE",          IDM_EDGE
        MENUITEM "Change Image Size\tShift+Z",  IDM_IMAGE_SIZE
        MENUITEM "S&tart",                      IDM_START
        MENUITEM "Setup Folder Paths",          IDM_PATHS
        MENUITEM "Use Default (Fractint) Palette\tCtrl+P", IDM_USEDEFAULTPALETTE
        MENUITEM "Display Location\tB",         IDM_DISPLAYLOC
        MENUITEM "Generate a statistics file for MPEG generation", IDM_GENMPEGSTATS
        MENUITEM "Setup Multi-threading for Perturbation and Slope\tCtrl+M", IDM_SETUPTHREADS
        MENUITEM "Setup Stereo Pair \tShift+D", IDM_STEREOPAIRSETUP
        MENUITEM "Toggle Display Palette \tShift+T", IDM_TOGGLE_DISPLAY_PALETTE
        MENUITEM SEPARATOR
        MENUITEM "Hailstone: Toggle &Axes\tCtrl+H", IDM_HAILSTONE_TOGGLE_AXES
        MENUITEM "Hailstone: Toggle &Labels\tCtrl+L", IDM_HAILSTONE_TOGGLE_LABELS
        MENUITEM "Hailstone: Toggle &Dots\tCtrl+G", IDM_HAILSTONE_TOGGLE_DOTS
    END
    POPUP "&Animation Generation"
    BEGIN
        MENUITEM "Setup &Zoom Animation\tCtrl+A", IDM_SETUPANIMATION
        MENUITEM "Setup &Julia Animation\tJ",   IDM_JULIA_ANIM
        MENUITEM "Setup Fourier Animation\tShift+F", IDM_FOURIERANIM
        MENUITEM "Setup Inversion Animation\tShift+I", IDM_INVERSION_ANIM
        MENUITEM "Setup Parameter Animation\tP", IDM_PARAM_ANIM
        MENUITEM "Setup 3D Oscillator, Fractal Map, Surface or Knot Animation\tCtrl+O", IDM_OSCILLATOR_ANIMATION
        MENUITEM "Morph Oscillators Between Sets of Axes\tShift+M", IDM_MORPHOSC
        MENUITEM SEPARATOR
        MENUITEM "&Stop Animation\tShift+S",    IDM_STOPANIM
        MENUITEM "Pause / &Resume Animation\tS", IDM_PAUSEANIM
    END
    POPUP "&Colour"
    BEGIN
        MENUITEM "Open Palette Colour Map\tQ",  IDM_OPEN_PAL_MAP
        MENUITEM "Open True Colour Map\tL",     IDM_OPEN_TRUE_MAP
        MENUITEM "Save True Colour Map As\tN",  IDM_SAVE_TRUE_MAP
        MENUITEM "Save Palette Colour Map\t Ctrl+N", IDM_SAVE_PAL_MAP
        MENUITEM "&Colour Cycle\t+ or -",       IDM_CYCLE
        MENUITEM "Change Colour Scheme\tC",     IDM_COLOUR_PAL
        MENUITEM "Set Inside Colour\tCtrl+S",   IDM_SETINSIDE
        MENUITEM "Edit Palette\tCtrl+E",        IDM_EDITPAL
        MENUITEM "Get Pixel Colour\tCtrl+R",    IDM_GET_PIXEL_COLOUR
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&ManpWin Help\tF1",           IDM_HELP
        MENUITEM SEPARATOR
        MENUITEM "&About ManpWin...",           IDM_ABOUT
    END
END


