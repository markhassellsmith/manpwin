CELLULARDLG DIALOG 16, 0, 259, 207
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION
CAPTION "Cellular Automata Parameters"
FONT 10, "Times New Roman"
BEGIN
    EDITTEXT        IDC_INIT_STRING,9,7,35,12
    LTEXT           "Rule = Number of Digits (see below) | 0 means Random",IDC_STATIC,78,29,171,10
    EDITTEXT        IDC_CELL_RULE,9,28,57,12
    PUSHBUTTON      "&OK",IDOK,20,180,83,14,WS_GROUP | NOT WS_TABSTOP
    PUSHBUTTON      "&CANCEL",IDCANCEL,146,180,92,14,WS_GROUP | NOT WS_TABSTOP
    LTEXT           "Type (see below)",IDC_STATIC,78,51,81,9
    EDITTEXT        IDC_CELL_TYPE,9,49,36,12
    LTEXT           "Initial String | 0 = Random | 1 = Reuse last Random",IDC_STATIC,78,9,158,8
    LTEXT           "    One-dimensional cellular automata or line automata.  The type of CA\n    is given by kr, where k is the number of different states of the\n    automata and r is the radius of the neighborhood.  The next generation",IDC_STATIC,12,103,225,24
    LTEXT           "    is determined by the sum of the neighborhood and the specified rule.\n    Four parameters: Initial String, Rule, Type, and Starting Row Number. ",IDC_STATIC,12,128,225,17
    LTEXT           "   For Type = 21, 31, 41, 51, 61, 22, 32, 42, 23, 33, 24, 25, 26, 27\n           Rule =  4,   7,  10, 13, 16,  6,  11, 16,  8,  15, 10, 12, 14, 16 digits\n",IDC_STATIC,20,147,199,19
    GROUPBOX        "",IDC_RED10,9,92,240,81,BS_CENTER
    LTEXT           "Starting Row Number",IDC_STATIC,78,72,81,9
    EDITTEXT        IDC_START_ROW,9,70,36,12
END

